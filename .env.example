COMPOSE_PROJECT_NAME=hdrezka_search
DATABASE_URL=postgresql://hdrezka_user:password@localhost:5432/hdrezka_filter
POSTGRES_USER=hdrezka_user
POSTGRES_PASSWORD=password
POSTGRES_DB=hdrezka_filter
APP_BIND=0.0.0.0
APP_PORT=8000
APP_USERS=user1:User 1,user2:User 2

# 0 = обычный режим, 1 = подробные SQL/debug logs в stdout/container logs.
HDREZKA_DEBUG=0
REZKA_BASE_URL=https://rezka.ag/
REZKA_USER_AGENT=Mozilla/5.0 (X11; Ubuntu; Linux x86_64; rv:149.0) Gecko/20100101 Firefox/149.0
REZKA_ACCEPT_LANGUAGE=en-US,en;q=0.9
REZKA_COOKIE=
REZKA_COOKIE_FILE=runtime/rezka_cookie.txt
REZKA_COOKIE_REFRESH_ENABLED=0
REZKA_COOKIE_REFRESH_URL=https://rezka.ag/new/
REZKA_COOKIE_REFRESH_HOUR=2
REZKA_COOKIE_REFRESH_MINUTE=0
# 0 = писать refreshed cookies только в REZKA_COOKIE_FILE, 1 = еще обновлять REZKA_COOKIE в локальном .env.
REZKA_COOKIE_REFRESH_WRITE_ENV=0

# Дефолтный источник CLI crawler-а: new, popular, best или genres.
CRAWLER_SOURCE=new
CRAWLER_PAGE_LIMIT=20
CRAWLER_ITEM_LIMIT=500
CRAWLER_SLEEP_SECONDS=1.0
CRAWLER_LOAD_MORE_PAGE_LIMIT=3
CRAWLER_LOAD_MORE_ITEM_LIMIT=30
CRAWLER_LOAD_MORE_IMDB_ITEM_LIMIT=0
CRAWLER_LOAD_MORE_SLEEP_SECONDS=0
CRAWLER_IMDB_ENABLED=1
CRAWLER_IMDB_ITEM_LIMIT=200
TELEGRAM_ALERTS_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
